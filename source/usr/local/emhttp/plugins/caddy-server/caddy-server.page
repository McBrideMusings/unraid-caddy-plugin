<script>
var csrfToken = csrf_token;
var statusUrl = "/plugins/caddy-server/php/status.php";

function fetchStatus() {
  var xhr = new XMLHttpRequest();
  xhr.open("GET", statusUrl + "?action=status", true);
  xhr.onreadystatechange = function() {
    if (xhr.readyState === 4 && xhr.status === 200) {
      try {
        var data = JSON.parse(xhr.responseText);
        var el = document.getElementById("caddy-status");
        if (data.running) {
          el.textContent = "Running";
          el.className = "running";
        } else {
          el.textContent = "Stopped";
          el.className = "stopped";
        }
        document.getElementById("caddy-version").textContent = "Caddy " + data.version;
        document.getElementById("caddy-log").textContent = data.log || "(empty)";

        var logEl = document.getElementById("caddy-log");
        logEl.scrollTop = logEl.scrollHeight;
      } catch(e) {}
    }
  };
  xhr.send();
}

function saveCaddyfile(reload) {
  var action = reload ? "save_and_reload" : "save_caddyfile";
  var content = document.getElementById("caddy-editor").value;
  var statusEl = document.getElementById("caddy-save-status");
  statusEl.textContent = "Saving...";

  var xhr = new XMLHttpRequest();
  xhr.open("POST", statusUrl + "?action=" + action, true);
  xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
  xhr.onreadystatechange = function() {
    if (xhr.readyState === 4) {
      try {
        var data = JSON.parse(xhr.responseText);
        if (data.success) {
          statusEl.textContent = reload ? "Saved and reloaded." : "Saved.";
        } else {
          statusEl.textContent = "Error: " + (data.error || data.output || "Unknown error");
        }
      } catch(e) {
        statusEl.textContent = "Error saving.";
      }
      setTimeout(function() { statusEl.textContent = ""; }, 5000);
    }
  };
  xhr.send("csrf_token=" + encodeURIComponent(csrfToken) + "&content=" + encodeURIComponent(content));
}

fetchStatus();
setInterval(fetchStatus, 5000);

// SSL platform detection
(function() {
  var ua = navigator.userAgent;
  var platform = 'macos';
  if (/iPhone|iPad|iPod/.test(ua)) platform = 'ios';
  else if (/Android/.test(ua)) platform = 'android';
  else if (/Windows/.test(ua)) platform = 'windows';
  else if (/Linux/.test(ua)) platform = 'linux';

  var el = document.getElementById('ssl-platform-' + platform);
  if (el) el.style.display = 'block';
})();

var sslShowAll = false;
function toggleAllPlatforms() {
  sslShowAll = !sslShowAll;
  var els = document.querySelectorAll('.ssl-platform');
  for (var i = 0; i < els.length; i++) {
    els[i].style.display = sslShowAll ? 'block' : 'none';
  }
  if (!sslShowAll) {
    // Re-detect and show current platform
    var ua = navigator.userAgent;
    var platform = 'macos';
    if (/iPhone|iPad|iPod/.test(ua)) platform = 'ios';
    else if (/Android/.test(ua)) platform = 'android';
    else if (/Windows/.test(ua)) platform = 'windows';
    else if (/Linux/.test(ua)) platform = 'linux';
    var el = document.getElementById('ssl-platform-' + platform);
    if (el) el.style.display = 'block';
  }
  document.getElementById('ssl-toggle-all').textContent = sslShowAll ? 'Show only my platform' : 'Show all platforms';
}

function copyCommand(el) {
  var text = el.textContent;
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text);
    el.title = 'Copied!';
    setTimeout(function() { el.title = 'Click to copy'; }, 2000);
  }
}

function toggleSection(id) {
  var toggle = document.getElementById(id + '-toggle');
  var body = document.getElementById(id + '-body');
  var open = toggle.classList.toggle('open');
  body.style.display = open ? 'block' : 'none';
  return open;
}

var interfacesLoaded = false;
function toggleInterfaces() {
  var open = toggleSection('interfaces');
  if (open && !interfacesLoaded) {
    interfacesLoaded = true;
    fetchInterfaces();
  }
}

function fetchInterfaces() {
  var xhr = new XMLHttpRequest();
  xhr.open("GET", statusUrl + "?action=interfaces", true);
  xhr.onreadystatechange = function() {
    if (xhr.readyState !== 4) return;
    var tbody = document.getElementById('interfaces-tbody');
    if (xhr.status !== 200) {
      tbody.innerHTML = '<tr><td colspan="4" style="color:red;">Failed to load interfaces.</td></tr>';
      return;
    }
    try {
      var data = JSON.parse(xhr.responseText);
      tbody.innerHTML = '';
      var ifaces = data.interfaces || [];
      for (var i = 0; i < ifaces.length; i++) {
        var iface = ifaces[i];
        var row = document.createElement('tr');

        var tdIface = document.createElement('td');
        tdIface.textContent = iface.interface || '\u2014';
        row.appendChild(tdIface);

        var tdIp = document.createElement('td');
        tdIp.textContent = iface.ip;
        row.appendChild(tdIp);

        var tdLabel = document.createElement('td');
        tdLabel.style.color = '#888';
        tdLabel.textContent = iface.label;
        row.appendChild(tdLabel);

        var tdAction = document.createElement('td');
        var btn = document.createElement('button');
        btn.className = 'copy-bind';
        btn.textContent = 'copy bind';
        btn.setAttribute('data-ip', iface.ip);
        btn.onclick = function() { copyBind(this.getAttribute('data-ip')); };
        tdAction.appendChild(btn);
        row.appendChild(tdAction);

        tbody.appendChild(row);
      }
    } catch(e) {
      tbody.innerHTML = '<tr><td colspan="4" style="color:red;">Failed to load interfaces.</td></tr>';
    }
  };
  xhr.send();
}

function copyBind(ip) {
  if (navigator.clipboard) {
    navigator.clipboard.writeText('    bind ' + ip);
  }
}

</script>
