<script>
var csrfToken = csrf_token;
var statusUrl = "/plugins/caddy-server/php/status.php";

function fetchStatus() {
  var xhr = new XMLHttpRequest();
  xhr.open("GET", statusUrl + "?action=status", true);
  xhr.onreadystatechange = function() {
    if (xhr.readyState === 4 && xhr.status === 200) {
      try {
        var data = JSON.parse(xhr.responseText);
        var el = document.getElementById("caddy-status");
        if (data.running) {
          el.textContent = "Running";
          el.className = "running";
        } else {
          el.textContent = "Stopped";
          el.className = "stopped";
        }
        document.getElementById("caddy-version").textContent = "Caddy " + data.version;
        document.getElementById("caddy-log").textContent = data.log || "(empty)";

        var logEl = document.getElementById("caddy-log");
        logEl.scrollTop = logEl.scrollHeight;
      } catch(e) {}
    }
  };
  xhr.send();
}

function saveCaddyfile(reload) {
  var action = reload ? "save_and_reload" : "save_caddyfile";
  var content = document.getElementById("caddy-editor").value;
  var statusEl = document.getElementById("caddy-save-status");
  statusEl.textContent = "Saving...";

  var xhr = new XMLHttpRequest();
  xhr.open("POST", statusUrl + "?action=" + action, true);
  xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
  xhr.onreadystatechange = function() {
    if (xhr.readyState === 4) {
      try {
        var data = JSON.parse(xhr.responseText);
        if (data.success) {
          statusEl.textContent = reload ? "Saved and reloaded." : "Saved.";
        } else {
          statusEl.textContent = "Error: " + (data.error || data.output || "Unknown error");
        }
      } catch(e) {
        statusEl.textContent = "Error saving.";
      }
      setTimeout(function() { statusEl.textContent = ""; }, 5000);
    }
  };
  xhr.send("csrf_token=" + encodeURIComponent(csrfToken) + "&content=" + encodeURIComponent(content));
}

fetchStatus();
setInterval(fetchStatus, 5000);

// SSL platform detection
(function() {
  var ua = navigator.userAgent;
  var platform = 'macos';
  if (/iPhone|iPad|iPod/.test(ua)) platform = 'ios';
  else if (/Android/.test(ua)) platform = 'android';
  else if (/Windows/.test(ua)) platform = 'windows';
  else if (/Linux/.test(ua)) platform = 'linux';

  var el = document.getElementById('ssl-platform-' + platform);
  if (el) el.style.display = 'block';
})();

var sslShowAll = false;
function toggleAllPlatforms() {
  sslShowAll = !sslShowAll;
  var els = document.querySelectorAll('.ssl-platform');
  for (var i = 0; i < els.length; i++) {
    els[i].style.display = sslShowAll ? 'block' : 'none';
  }
  if (!sslShowAll) {
    // Re-detect and show current platform
    var ua = navigator.userAgent;
    var platform = 'macos';
    if (/iPhone|iPad|iPod/.test(ua)) platform = 'ios';
    else if (/Android/.test(ua)) platform = 'android';
    else if (/Windows/.test(ua)) platform = 'windows';
    else if (/Linux/.test(ua)) platform = 'linux';
    var el = document.getElementById('ssl-platform-' + platform);
    if (el) el.style.display = 'block';
  }
  document.getElementById('ssl-toggle-all').textContent = sslShowAll ? 'Show only my platform' : 'Show all platforms';
}

function copyCommand(el) {
  var text = el.textContent;
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text);
    el.title = 'Copied!';
    setTimeout(function() { el.title = 'Click to copy'; }, 2000);
  }
}

function toggleSection(id) {
  var toggle = document.getElementById(id + '-toggle');
  var body = document.getElementById(id + '-body');
  var open = toggle.classList.toggle('open');
  body.style.display = open ? 'block' : 'none';
  return open;
}

var interfacesLoaded = false;
function toggleInterfaces() {
  var open = toggleSection('interfaces');
  if (open && !interfacesLoaded) {
    interfacesLoaded = true;
    fetchInterfaces();
  }
}

function fetchInterfaces() {
  var xhr = new XMLHttpRequest();
  xhr.open("GET", statusUrl + "?action=interfaces", true);
  xhr.onreadystatechange = function() {
    if (xhr.readyState !== 4) return;
    var tbody = document.getElementById('interfaces-tbody');
    if (xhr.status !== 200) {
      tbody.innerHTML = '<tr><td colspan="4" style="color:red;">Failed to load interfaces.</td></tr>';
      return;
    }
    try {
      var data = JSON.parse(xhr.responseText);
      tbody.innerHTML = '';
      var ifaces = data.interfaces || [];
      for (var i = 0; i < ifaces.length; i++) {
        var iface = ifaces[i];
        var row = document.createElement('tr');

        var tdIface = document.createElement('td');
        tdIface.textContent = iface.interface || '\u2014';
        row.appendChild(tdIface);

        var tdIp = document.createElement('td');
        tdIp.textContent = iface.ip;
        row.appendChild(tdIp);

        var tdLabel = document.createElement('td');
        tdLabel.style.color = '#888';
        tdLabel.textContent = iface.label;
        row.appendChild(tdLabel);

        var tdAction = document.createElement('td');
        var btn = document.createElement('button');
        btn.className = 'copy-bind';
        btn.textContent = 'copy bind';
        btn.setAttribute('data-ip', iface.ip);
        btn.onclick = function() { copyBind(this.getAttribute('data-ip')); };
        tdAction.appendChild(btn);
        row.appendChild(tdAction);

        tbody.appendChild(row);
      }
    } catch(e) {
      tbody.innerHTML = '<tr><td colspan="4" style="color:red;">Failed to load interfaces.</td></tr>';
    }
  };
  xhr.send();
}

function copyBind(ip) {
  if (navigator.clipboard) {
    navigator.clipboard.writeText('    bind ' + ip);
  }
}

var modulesLoaded = false;
function toggleModules() {
  var open = toggleSection('modules');
  if (open && !modulesLoaded) {
    modulesLoaded = true;
    fetchModules();
  }
}

function updateModuleButtons(data) {
  var restoreBtn = document.getElementById('modules-restore-btn');
  var stagedSection = document.getElementById('modules-staged-section');
  var stagedInfo = document.getElementById('modules-staged-info');
  var stagedVer = document.getElementById('modules-staged-ver');

  restoreBtn.style.display = data.has_backup ? 'inline-block' : 'none';

  if (data.staged_ready) {
    stagedSection.style.display = 'block';
    stagedVer.textContent = data.staged_version ? "(" + data.staged_version + ")" : "";
    var mods = data.staged_modules || [];
    if (mods.length === 0) {
      stagedInfo.textContent = "No non-standard modules (stock build)";
    } else {
      var lines = [];
      for (var i = 0; i < mods.length; i++) {
        lines.push(mods[i].module + "  " + mods[i].package);
      }
      stagedInfo.textContent = mods.length + " non-standard module" + (mods.length > 1 ? "s" : "") + ":\n" + lines.join("\n");
    }
  } else {
    stagedSection.style.display = 'none';
  }
}

function fetchModules() {
  var xhr = new XMLHttpRequest();
  xhr.open("GET", statusUrl + "?action=modules", true);
  xhr.onreadystatechange = function() {
    if (xhr.readyState !== 4) return;
    var listEl = document.getElementById('modules-list');
    var editorEl = document.getElementById('modules-editor');
    if (xhr.status !== 200) {
      listEl.textContent = "Failed to load module info.";
      return;
    }
    try {
      var data = JSON.parse(xhr.responseText);
      var installed = data.installed_modules || [];
      if (installed.length === 0) {
        listEl.textContent = "No non-standard modules installed.";
      } else {
        var lines = [];
        for (var i = 0; i < installed.length; i++) {
          lines.push(installed[i].module + " (" + installed[i].package + ")");
        }
        listEl.textContent = lines.join("\n");
      }
      var configured = data.configured_modules || [];
      if (configured.length > 0) {
        editorEl.value = configured.join("\n");
      }
      updateModuleButtons(data);
    } catch(e) {
      listEl.textContent = "Failed to parse module info.";
    }
  };
  xhr.send();
}

var rebuildProgressTimer = null;

function pollRebuildProgress() {
  var statusEl = document.getElementById('modules-status');
  var barEl = document.getElementById('modules-progress-bar');
  var xhr = new XMLHttpRequest();
  xhr.open("GET", statusUrl + "?action=rebuild_progress", true);
  xhr.onreadystatechange = function() {
    if (xhr.readyState !== 4 || xhr.status !== 200) return;
    try {
      var data = JSON.parse(xhr.responseText);
      if (data.step) {
        statusEl.textContent = data.step;
        barEl.style.display = 'block';
        barEl.querySelector('div').style.width = data.progress + '%';
      }
    } catch(e) {}
  };
  xhr.send();
}

function downloadCaddy() {
  var editor = document.getElementById('modules-editor');
  var statusEl = document.getElementById('modules-status');
  var barEl = document.getElementById('modules-progress-bar');
  var modules = editor.value.trim();

  if (!modules) {
    statusEl.textContent = "Enter at least one module path.";
    statusEl.style.color = "red";
    setTimeout(function() { statusEl.textContent = ""; }, 5000);
    return;
  }

  statusEl.textContent = "Starting download...";
  statusEl.style.color = "#888";
  barEl.style.display = 'block';
  barEl.querySelector('div').style.width = '0%';

  var btns = document.querySelectorAll('#modules-body button');
  for (var i = 0; i < btns.length; i++) btns[i].disabled = true;

  rebuildProgressTimer = setInterval(pollRebuildProgress, 1500);

  var xhr = new XMLHttpRequest();
  xhr.open("POST", statusUrl + "?action=download_caddy", true);
  xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
  xhr.onreadystatechange = function() {
    if (xhr.readyState !== 4) return;
    clearInterval(rebuildProgressTimer);
    for (var i = 0; i < btns.length; i++) btns[i].disabled = false;
    try {
      var data = JSON.parse(xhr.responseText);
      if (data.success) {
        barEl.querySelector('div').style.width = '100%';
        statusEl.textContent = "Download complete — review staged binary above, then install.";
        statusEl.style.color = "green";
        fetchModules();
      } else {
        statusEl.textContent = "Error: " + (data.error || "Unknown error") + (data.detail ? " — " + data.detail : "");
        statusEl.style.color = "red";
      }
    } catch(e) {
      statusEl.textContent = "Error: " + xhr.responseText;
      statusEl.style.color = "red";
    }
    setTimeout(function() { barEl.style.display = 'none'; }, 3000);
    setTimeout(function() { statusEl.textContent = ""; }, 10000);
  };
  xhr.send("csrf_token=" + encodeURIComponent(csrfToken) + "&modules=" + encodeURIComponent(modules));
}

function installCaddy() {
  if (!confirm("Install the staged custom binary? Caddy will be briefly restarted if running.")) return;

  var statusEl = document.getElementById('modules-install-status');
  statusEl.textContent = "Installing...";
  statusEl.style.color = "#888";

  var btns = document.querySelectorAll('#modules-staged-section button');
  for (var i = 0; i < btns.length; i++) btns[i].disabled = true;

  var xhr = new XMLHttpRequest();
  xhr.open("POST", statusUrl + "?action=install_caddy", true);
  xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
  xhr.onreadystatechange = function() {
    if (xhr.readyState !== 4) return;
    for (var i = 0; i < btns.length; i++) btns[i].disabled = false;
    try {
      var data = JSON.parse(xhr.responseText);
      if (data.success) {
        statusEl.textContent = "Installed — " + data.version + (data.restarted ? " (restarted)" : "");
        statusEl.style.color = "green";
        fetchModules();
        fetchStatus();
      } else {
        statusEl.textContent = "Error: " + (data.error || "Unknown error") + (data.detail ? " — " + data.detail : "");
        statusEl.style.color = "red";
      }
    } catch(e) {
      statusEl.textContent = "Error installing.";
      statusEl.style.color = "red";
    }
    setTimeout(function() { statusEl.textContent = ""; }, 15000);
  };
  xhr.send("csrf_token=" + encodeURIComponent(csrfToken));
}

function deleteStaged() {
  var statusEl = document.getElementById('modules-install-status');
  var xhr = new XMLHttpRequest();
  xhr.open("POST", statusUrl + "?action=delete_staged", true);
  xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
  xhr.onreadystatechange = function() {
    if (xhr.readyState !== 4) return;
    fetchModules();
  };
  xhr.send("csrf_token=" + encodeURIComponent(csrfToken));
}

function restoreCaddy() {
  if (!confirm("Restore the stock Caddy binary? This will remove all custom modules.")) return;

  var statusEl = document.getElementById('modules-status');
  statusEl.textContent = "Restoring stock binary...";
  statusEl.style.color = "#888";

  var xhr = new XMLHttpRequest();
  xhr.open("POST", statusUrl + "?action=restore_caddy", true);
  xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
  xhr.onreadystatechange = function() {
    if (xhr.readyState !== 4) return;
    try {
      var data = JSON.parse(xhr.responseText);
      if (data.success) {
        statusEl.textContent = "Restored — " + data.version;
        statusEl.style.color = "green";
        document.getElementById('modules-editor').value = "";
        fetchModules();
        fetchStatus();
      } else {
        statusEl.textContent = "Error: " + (data.error || "Unknown error");
        statusEl.style.color = "red";
      }
    } catch(e) {
      statusEl.textContent = "Error restoring.";
      statusEl.style.color = "red";
    }
    setTimeout(function() { statusEl.textContent = ""; }, 10000);
  };
  xhr.send("csrf_token=" + encodeURIComponent(csrfToken));
}

</script>
