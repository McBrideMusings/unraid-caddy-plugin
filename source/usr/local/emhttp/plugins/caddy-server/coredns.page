Menu="NetworkServices"
Title="CoreDNS"
Icon="fa-sitemap"
---
<?php
$plugin = "caddy-server";
$configDir = "/boot/config/plugins/{$plugin}";
$configFile = "{$configDir}/{$plugin}.cfg";
$logFile = "/var/log/coredns.log";
$pidFile = "/var/run/coredns.pid";
$runDir = "/var/run/coredns";

$cfg = parse_ini_file($configFile) ?: [];
$corednsService = $cfg["COREDNS_SERVICE"] ?? "disable";
$dnsZones = $cfg["DNS_ZONES"] ?? ($cfg["DNS_ZONE"] ?? "");
// Normalize: display one zone per line
$dnsZonesDisplay = trim(preg_replace('/[\s,]+/', "\n", $dnsZones));
$dnsIp = $cfg["DNS_IP"] ?? "";
$dnsBind = $cfg["DNS_BIND"] ?? "";

$running = false;
if (file_exists($pidFile)) {
    $pid = trim(file_get_contents($pidFile));
    if ($pid && file_exists("/proc/{$pid}")) {
        $running = true;
    }
}

// Read all generated zone files
$zoneFiles = [];
foreach (glob("{$runDir}/db.*.zone") ?: [] as $zf) {
    $zoneFiles[basename($zf)] = file_get_contents($zf);
}
// Legacy single-file fallback
if (empty($zoneFiles) && file_exists("{$runDir}/db.zone")) {
    $zoneFiles["db.zone"] = file_get_contents("{$runDir}/db.zone");
}

$csrf = _var($var,'csrf_token');
?>

<style>
#coredns-status { font-weight: bold; }
#coredns-status.running { color: green; }
#coredns-status.stopped { color: red; }
#coredns-log { font-family: monospace; font-size: 12px; white-space: pre-wrap; word-wrap: break-word;
             background: #1a1a2e; color: #e0e0e0; padding: 10px; max-height: 400px; overflow-y: auto; }
#coredns-zone-preview { font-family: monospace; font-size: 12px; white-space: pre-wrap;
             background: #1a1a2e; color: #e0e0e0; padding: 10px; }
</style>

<div>
  <span>Status: </span>
  <span id="coredns-status" class="<?= $running ? 'running' : 'stopped' ?>">
    <?= $running ? 'Running' : 'Stopped' ?>
  </span>
</div>
<hr>

<form markdown="1" method="POST" action="/update.htm" target="progressFrame">
  <input type="hidden" name="csrf_token" value="<?=$csrf?>">
  <dl>
    <dt>Enable CoreDNS:</dt>
    <dd>
      <select name="#command" onchange="this.form.submit()">
        <option value="/etc/rc.d/rc.coredns enable" <?= $corednsService === "enable" ? 'selected' : '' ?>>Yes</option>
        <option value="/etc/rc.d/rc.coredns disable" <?= $corednsService !== "enable" ? 'selected' : '' ?>>No</option>
      </select>
    </dd>
  </dl>
</form>

<?php if ($corednsService === "enable"): ?>
<div style="margin-bottom: 20px;">
  <form method="POST" action="/update.htm" target="progressFrame" style="display:inline">
    <input type="hidden" name="csrf_token" value="<?=$csrf?>">
    <input type="hidden" name="#command" value="/etc/rc.d/rc.coredns start">
    <button type="submit" <?= $running ? 'disabled' : '' ?>>Start</button>
  </form>
  <form method="POST" action="/update.htm" target="progressFrame" style="display:inline">
    <input type="hidden" name="csrf_token" value="<?=$csrf?>">
    <input type="hidden" name="#command" value="/etc/rc.d/rc.coredns stop">
    <button type="submit" <?= !$running ? 'disabled' : '' ?>>Stop</button>
  </form>
  <form method="POST" action="/update.htm" target="progressFrame" style="display:inline">
    <input type="hidden" name="csrf_token" value="<?=$csrf?>">
    <input type="hidden" name="#command" value="/etc/rc.d/rc.coredns restart">
    <button type="submit" <?= !$running ? 'disabled' : '' ?>>Restart</button>
  </form>
</div>

<script>
var csrfToken = csrf_token;

function saveDnsSettings() {
  var zones = document.getElementById('dns-zones-input').value;
  var ip = document.getElementById('dns-ip-input').value;
  var bind = document.getElementById('dns-bind-input').value;
  var statusEl = document.getElementById('dns-save-status');
  statusEl.textContent = "Saving...";

  var xhr = new XMLHttpRequest();
  xhr.open("POST", "/plugins/caddy-server/php/coredns-status.php?action=save_settings", true);
  xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
  xhr.onreadystatechange = function() {
    if (xhr.readyState === 4) {
      try {
        var data = JSON.parse(xhr.responseText);
        if (data.success) {
          statusEl.textContent = "Saved. Restart CoreDNS to apply changes.";
        } else {
          statusEl.textContent = "Error: " + (data.error || "Unknown error");
        }
      } catch(e) {
        statusEl.textContent = "Error saving.";
      }
      setTimeout(function() { statusEl.textContent = ""; }, 5000);
    }
  };
  xhr.send("csrf_token=" + encodeURIComponent(csrfToken) + "&dns_zones=" + encodeURIComponent(zones) + "&dns_ip=" + encodeURIComponent(ip) + "&dns_bind=" + encodeURIComponent(bind));
}
</script>

<div style="margin-bottom: 20px;">
  <strong>DNS Settings</strong>
  <br><br>
  <table>
    <tr>
      <td style="padding-right: 15px; vertical-align: top;">Zone Names:</td>
      <td>
        <textarea id="dns-zones-input" rows="3" style="width: 300px; font-family: monospace;" placeholder="myserver.local&#10;myserver.lan"><?= htmlspecialchars($dnsZonesDisplay) ?></textarea>
        <br><span style="color: #888;">One zone per line (or space-separated). Each is served as its own DNS zone pointing to the IP below.</span>
      </td>
    </tr>
    <tr>
      <td style="padding-right: 15px;">IP Address:</td>
      <td>
        <input type="text" id="dns-ip-input" value="<?= htmlspecialchars($dnsIp) ?>" placeholder="e.g. 100.x.x.x or 192.168.1.x" style="width: 300px;">
        <span style="color: #888; margin-left: 8px;">What *.zone resolves to</span>
      </td>
    </tr>
    <tr>
      <td style="padding-right: 15px;">Bind Address:</td>
      <td>
        <input type="text" id="dns-bind-input" value="<?= htmlspecialchars($dnsBind) ?>" placeholder="defaults to IP address" style="width: 300px;">
        <span style="color: #888; margin-left: 8px;">Interface CoreDNS listens on (leave blank to use IP address)</span>
      </td>
    </tr>
  </table>
  <br>
  <button onclick="saveDnsSettings()">Save Settings</button>
  <span id="dns-save-status" style="margin-left: 8px;"></span>
</div>

<?php if (!empty($zoneFiles)): ?>
<div style="margin-bottom: 20px;">
  <strong>Generated Zone Files</strong>
  <br><br>
  <?php foreach ($zoneFiles as $name => $content): ?>
    <div style="color: #888; font-family: monospace; margin-top: 8px;"><?= htmlspecialchars($name) ?></div>
    <pre class="coredns-zone-preview" style="font-family: monospace; font-size: 12px; white-space: pre-wrap; background: #1a1a2e; color: #e0e0e0; padding: 10px;"><?= htmlspecialchars($content) ?></pre>
  <?php endforeach; ?>
</div>
<?php endif; ?>

<div>
  <strong>Log</strong>
  <br><br>
  <pre id="coredns-log">Loading...</pre>
</div>

<script>
function fetchCoreDnsStatus() {
  var xhr = new XMLHttpRequest();
  xhr.open("GET", "/plugins/caddy-server/php/coredns-status.php?action=status", true);
  xhr.onreadystatechange = function() {
    if (xhr.readyState === 4 && xhr.status === 200) {
      try {
        var data = JSON.parse(xhr.responseText);
        var el = document.getElementById("coredns-status");
        if (data.running) {
          el.textContent = "Running";
          el.className = "running";
        } else {
          el.textContent = "Stopped";
          el.className = "stopped";
        }
        document.getElementById("coredns-log").textContent = data.log || "(empty)";
        var logEl = document.getElementById("coredns-log");
        logEl.scrollTop = logEl.scrollHeight;
      } catch(e) {}
    }
  };
  xhr.send();
}
fetchCoreDnsStatus();
setInterval(fetchCoreDnsStatus, 5000);
</script>
<?php endif; ?>
